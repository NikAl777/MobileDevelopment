    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Информация о Дизайне"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Дизайн в современном мире - это проектная деятельность, направленная на решение функциональных, эстетических и коммуникационных задач. Главная функция дизайна — сделать объект полезным, понятным и привлекательным для пользователя."
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Добавьте изображение или больше текста по желанию -->
    </LinearLayout>
</ScrollView>